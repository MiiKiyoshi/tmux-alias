#!/bin/bash
# stt - tmux session의 pane별 foreground 프로세스 CPU/GPU 메모리 사용량
#
# Usage:
#   stt                 세션별 총합 (compact)
#   stt <session>       해당 세션 상세 출력
#   stt -v              전체 세션 상세 출력
#   stt -w              5초마다 갱신 (watch 모드)

verbose=0
watch_mode=0
session=""

for arg in "$@"; do
  case "$arg" in
    -v) verbose=1 ;;
    -w) watch_mode=1 ;;
    *)  session="$arg" ;;
  esac
done

# 세션 존재 확인
if [ -n "$session" ]; then
  if ! tmux has-session -t "=$session" 2>/dev/null; then
    echo "Session not found: $session" >&2
    exit 1
  fi
fi

# 출력 모드: 세션 지정 또는 -v → 상세, 그 외 → compact
if [ -n "$session" ] || [ "$verbose" -eq 1 ]; then
  detail=1
else
  detail=0
fi

# 색상: 파이프 출력 시 비활성화
if [ -t 1 ]; then
  use_color=1
else
  use_color=0
fi

# 초록→노랑→빨강 11단계 색상 테이블 (256-color)
_clut=(46 82 118 154 190 226 220 214 208 202 196)

# 반환값을 _r에 저장 (서브셸 회피)
fmt_mem() {
  local kib=$1
  if [ "$kib" -ge 1048576 ]; then
    _r="$((kib / 1048576)).$((kib % 1048576 * 10 / 1048576)) GiB"
  elif [ "$kib" -ge 1024 ]; then
    _r="$((kib / 1024)).$((kib % 1024 * 10 / 1024)) MiB"
  else
    _r="${kib} KiB"
  fi
}

fmt_gpu() {
  local mib=$1
  if [ "$mib" -ge 1024 ]; then
    _r="$((mib / 1024)).$((mib % 1024 * 10 / 1024)) GiB"
  elif [ "$mib" -gt 0 ]; then
    _r="${mib} MiB"
  else
    _r="-"
  fi
}

color_cpu() {
  local kib=$1; shift
  if [ "$use_color" -eq 0 ] || [ "$kib" -lt 102400 ]; then
    printf '%s' "$*"; return
  fi
  local idx=$(( (kib - 102400) * 10 / 4091904 ))
  [ "$idx" -gt 10 ] && idx=10
  printf '\033[38;5;%dm%s\033[0m' "${_clut[$idx]}" "$*"
}

color_gpu() {
  local mib=$1; shift
  if [ "$use_color" -eq 0 ] || [ "$mib" -le 0 ]; then
    printf '%s' "$*"; return
  fi
  local idx=$(( (mib - 100) * 10 / 3996 ))
  [ "$idx" -lt 0 ] && idx=0
  [ "$idx" -gt 10 ] && idx=10
  printf '\033[38;5;%dm%s\033[0m' "${_clut[$idx]}" "$*"
}

# 데이터 수집: 외부 프로세스 3회 (nvidia-smi, tmux, ps)
collect() {
  # GPU 메모리 맵 (pid -> MiB)
  declare -gA gpu_map=()
  while IFS=', ' read -r pid mem_mib _; do
    [ -n "$pid" ] && gpu_map[$pid]=$mem_mib
  done < <(nvidia-smi --query-compute-apps=pid,used_memory --format=csv,noheader,nounits 2>/dev/null)

  # foreground 프로세스만 tty별로 분류 (전체 ps 순회 1회)
  declare -gA tty_procs=()
  while read -r stat pid rss ps_tty args; do
    [ -z "$stat" ] && continue
    [[ "$stat" == *"+"* ]] || continue
    tty_procs[$ps_tty]+="$pid $rss $args"$'\n'
  done < <(ps -eo stat=,pid=,rss=,tty=,args= 2>/dev/null)

  # tmux pane 목록
  local tmux_fmt='#{session_name}|#{window_index}|#{window_name}|#{pane_index}|#{pane_tty}'
  if [ -n "$session" ]; then
    tmux_panes=$(tmux list-panes -s -t "=$session" -F "$tmux_fmt" 2>/dev/null)
  else
    tmux_panes=$(tmux list-panes -a -F "$tmux_fmt" 2>/dev/null)
  fi
}

render() {
  [ -z "$tmux_panes" ] && { echo "No tmux sessions found" >&2; return 1; }

  local prev_ses=""
  local ses_rss=0 ses_gpu=0
  local ses_lines=() max_cmd=0
  local first_ses=1

  flush_session() {
    [ -z "$prev_ses" ] && return
    if [ "$detail" -eq 0 ]; then
      # compact: 세션별 한 줄
      fmt_mem "$ses_rss"; printf -v cpu_pad '%-12s' "$_r"
      fmt_gpu "$ses_gpu"; printf -v gpu_pad '%s' "$_r"
      printf '%-20s' "$prev_ses"
      color_cpu "$ses_rss" "$cpu_pad"
      printf ' '
      color_gpu "$ses_gpu" "$gpu_pad"
      printf '\n'
    else
      # 상세: pane별 출력, single-pane window는 병합
      [ "$first_ses" -eq 0 ] && echo "---"
      # window별 pane 수, single-pane label 최대 길이
      local -A _wpc=()
      local _max_label=0
      local f_widx f_wname f_pidx f_cmd f_rss f_gpu
      for line in "${ses_lines[@]}"; do
        IFS='|' read -r f_widx f_wname _ _ _ _ <<< "$line"
        _wpc[$f_widx]=$(( ${_wpc[$f_widx]:-0} + 1 ))
      done
      for line in "${ses_lines[@]}"; do
        IFS='|' read -r f_widx f_wname _ _ _ _ <<< "$line"
        if [ "${_wpc[$f_widx]}" -eq 1 ]; then
          local _ll=$(( ${#f_widx} + 1 + ${#f_wname} ))
          [ "$_ll" -gt "$_max_label" ] && _max_label="$_ll"
        fi
      done

      # col_offset: multi-pane(7+cmd) vs single-pane(2+label+4+cmd) 중 큰 값
      local col_mp=$((max_cmd + 7))
      local col_sp=$((_max_label + max_cmd + 6))
      local col_offset=$(( col_mp > col_sp ? col_mp : col_sp ))

      printf '%-*s  %-12s %s\n' "$col_offset" "$prev_ses" 'CPU' 'GPU'

      local pw=""
      for line in "${ses_lines[@]}"; do
        IFS='|' read -r f_widx f_wname f_pidx f_cmd f_rss f_gpu <<< "$line"
        fmt_mem "$f_rss"; printf -v cpu_pad '%-12s' "$_r"
        fmt_gpu "$f_gpu"; printf -v gpu_pad '%s' "$_r"

        if [ "${_wpc[$f_widx]}" -eq 1 ]; then
          # single-pane: window+pane 한 줄
          printf '  %-*s  %-*s  ' "$_max_label" "${f_widx}:${f_wname}" "$((col_offset - _max_label - 4))" "$f_cmd"
          color_cpu "$f_rss" "$cpu_pad"
          printf ' '
          color_gpu "$f_gpu" "$gpu_pad"
          printf '\n'
          pw="$f_widx"
        else
          # multi-pane: window 헤더 + pane 행
          if [ "$f_widx" != "$pw" ]; then
            echo "  ${f_widx}:${f_wname}"
            pw="$f_widx"
          fi
          printf '    %s: %-*s  ' "$f_pidx" "$((col_offset - 7))" "$f_cmd"
          color_cpu "$f_rss" "$cpu_pad"
          printf ' '
          color_gpu "$f_gpu" "$gpu_pad"
          printf '\n'
        fi
      done
      printf '%-*s  ' "$col_offset" 'Total'
      fmt_mem "$ses_rss"; printf -v cpu_pad '%-12s' "$_r"
      fmt_gpu "$ses_gpu"; printf -v gpu_pad '%s' "$_r"
      color_cpu "$ses_rss" "$cpu_pad"
      printf ' '
      color_gpu "$ses_gpu" "$gpu_pad"
      printf '\n'
    fi
    first_ses=0
  }

  # 컬럼 헤더
  if [ "$detail" -eq 0 ]; then
    printf '%-20s%-12s %s\n' 'SESSION' 'CPU' 'GPU'
  fi

  while IFS='|' read -r ses widx wname pidx tty; do
    [ -n "$tty" ] || continue

    if [ "$ses" != "$prev_ses" ]; then
      flush_session
      prev_ses="$ses"
      ses_rss=0
      ses_gpu=0
      ses_lines=()
      max_cmd=0
    fi

    local pane_rss=0 pane_gpu=0 fg_cmd=""
    local short_tty=${tty#/dev/}

    # tty별 전처리된 foreground 프로세스에서 매칭
    while read -r pid rss args; do
      [ -z "$pid" ] && continue

      if [ -z "$fg_cmd" ]; then
        local base=${args%% *}
        base=${base##*/}
        case "$base" in
          bash|zsh|sh|fish|-bash|-zsh|-sh|-fish) ;;
          *) fg_cmd="$base" ;;
        esac
      fi

      pane_rss=$((pane_rss + rss))
      [ -n "${gpu_map[$pid]+x}" ] && pane_gpu=$((pane_gpu + gpu_map[$pid]))
    done <<< "${tty_procs[$short_tty]}"

    [ -z "$fg_cmd" ] && fg_cmd="(shell)"

    ses_rss=$((ses_rss + pane_rss))
    ses_gpu=$((ses_gpu + pane_gpu))

    [ ${#fg_cmd} -gt $max_cmd ] && max_cmd=${#fg_cmd}
    ses_lines+=("$widx|$wname|$pidx|$fg_cmd|$pane_rss|$pane_gpu")
  done <<< "$tmux_panes"

  flush_session
}

if [ "$watch_mode" -eq 1 ]; then
  tmpf="/tmp/stt.$$"
  tput civis 2>/dev/null
  trap 'tput cnorm 2>/dev/null; rm -f "$tmpf"; exit 0' INT EXIT
  while true; do
    collect
    render > "$tmpf"
    clear
    printf '[%s]\n' "$(date '+%H:%M:%S')"
    cat "$tmpf"
    sleep 5
  done
else
  collect
  render
fi
