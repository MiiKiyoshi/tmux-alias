#!/usr/bin/env bash
# mkt - tmux 세션/윈도우/pane 생성
#
# Usage:
#   mkt t5              세션 생성
#   mkt t5:3            인덱스로 윈도우 생성
#   mkt t5:train        이름으로 윈도우 생성
#   mkt t5:3.0          pane 생성 (split, 기본 좌우)
#   mkt t5:train.0      pane 생성 (이름 기반 윈도우)
#   mkt -p t5:train     세션/윈도우 없어도 자동 생성
#   mkt -h t5:3.0       좌우 split
#   mkt -v t5:3.0       위아래 split
#   mkt t5:{a,b,c}      다중 생성 (shell brace expansion)

split_opt="-h"
parents=0

while getopts "hvp" opt; do
  case $opt in
    h) split_opt="-h" ;;
    v) split_opt="-v" ;;
    p) parents=1 ;;
    *) echo "Usage: mkt [-h|-v] [-p] <target>..." >&2; exit 1 ;;
  esac
done
shift $((OPTIND-1))

[ -z "$1" ] && { echo "Usage: mkt [-h|-v] [-p] <target>..." >&2; exit 1; }

exit_code=0
for target in "$@"; do
  if [[ "$target" =~ ^([^:]+):([^.]+)\.([0-9]+)$ ]]; then
    # pane 생성 (split)
    sess="${BASH_REMATCH[1]}"
    win="${BASH_REMATCH[2]}"
    pane="${BASH_REMATCH[3]}"
    if [ "$parents" -eq 1 ]; then
      if ! tmux has-session -t "=$sess" 2>/dev/null; then
        tmux new-session -d -s "$sess"
      fi
      if [[ "$win" =~ ^[0-9]+$ ]]; then
        if ! tmux list-windows -t "=$sess" -F '#{window_index}' | grep -qx "$win"; then
          tmux new-window -t "=$sess:$win"
        fi
      else
        if ! tmux list-windows -t "=$sess" -F '#{window_name}' | grep -qx "$win"; then
          tmux new-window -t "=$sess" -n "$win"
        fi
      fi
    fi
    if [[ "$win" =~ ^[0-9]+$ ]]; then
      tmux split-window $split_opt -t "=$sess:${win}.${pane}"
    else
      tmux split-window $split_opt -t "=$sess:=$win.${pane}"
    fi
  elif [[ "$target" =~ ^([^:]+):([^.]+)$ ]]; then
    # 윈도우 생성
    sess="${BASH_REMATCH[1]}"
    win="${BASH_REMATCH[2]}"
    if ! tmux has-session -t "=$sess" 2>/dev/null; then
      if [ "$parents" -eq 1 ]; then
        tmux new-session -d -s "$sess"
      else
        echo "mkt: session not found: $sess" >&2
        exit_code=1
        continue
      fi
    fi
    if [[ "$win" =~ ^[0-9]+$ ]]; then
      tmux new-window -t "=$sess:$win"
    else
      if tmux list-windows -t "=$sess" -F '#{window_name}' | grep -qx "$win"; then
        echo "mkt: window already exists: $sess:$win" >&2
        exit_code=1
        continue
      fi
      tmux new-window -t "=$sess" -n "$win"
    fi
  else
    # 세션 생성
    if tmux has-session -t "=$target" 2>/dev/null; then
      echo "mkt: session already exists: $target" >&2
      exit_code=1
      continue
    fi
    tmux new-session -d -s "$target"
  fi
done
exit $exit_code
