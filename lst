#!/bin/bash
# lst - tmux pane 목록 (계층적 출력, 현재 위치에 * 표시)
#
# Usage:
#   lst      기본 (실행파일 basename, 긴 경로 축약)
#   lst -v   verbose (전체 경로 표시)

verbose=0
while getopts "v" opt; do
  case $opt in
    v) verbose=1 ;;
  esac
done

# 경로 축약: 맨 앞 유지, 중간 첫글자, 마지막 유지
# ~/tools/micromamba/envs/kiyoshi/bin/gpustat → ~/tools/m/e/k/b/gpustat
shorten_path() {
  local p="$1"
  local threshold=40

  [ ${#p} -le $threshold ] && { echo "$p"; return; }

  local prefix="" rest="$p"

  # ~/ 또는 / 로 시작하는 경우 첫 디렉토리까지 보존
  if [[ "$p" == "~/"* ]]; then
    prefix="~/"
    rest="${p#\~/}"
    # 첫 디렉토리 보존
    local first="${rest%%/*}"
    if [[ "$rest" == */* ]]; then
      prefix="~/$first/"
      rest="${rest#*/}"
    else
      echo "$p"; return
    fi
  elif [[ "$p" == /* ]]; then
    rest="${p#/}"
    local first="${rest%%/*}"
    if [[ "$rest" == */* ]]; then
      prefix="/$first/"
      rest="${rest#*/}"
    else
      echo "$p"; return
    fi
  else
    echo "$p"; return
  fi

  # 마지막 컴포넌트 분리
  local last="${rest##*/}"
  local middle="${rest%/*}"

  if [ "$middle" = "$rest" ]; then
    # 중간 없음
    echo "${prefix}${last}"
    return
  fi

  # 중간 디렉토리들 첫 글자로
  local short_middle=""
  IFS='/' read -ra parts <<< "$middle"
  for part in "${parts[@]}"; do
    [ -n "$part" ] && short_middle+="${part:0:1}/"
  done

  echo "${prefix}${short_middle}${last}"
}

prev_s=""
prev_w=""

# 현재 위치 (tmux 안에서 실행 시에만)
if [ -n "$TMUX" ]; then
  cur=$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
  cur_s="${cur%%:*}"
  cur_wp="${cur#*:}"
  cur_w="${cur_wp%%.*}"
  cur_p="${cur_wp#*.}"
fi

# 데이터 수집
lines=()
max_cmd_len=0

while IFS='|' read -r s widx wname pidx tty cwd; do
  [ -n "$tty" ] || continue
  cmd=$(ps -t "$tty" -o stat=,args= 2>/dev/null | awk '$1 ~ /\+/{ $1=""; sub(/^ +/,""); print; exit }')
  cmd=${cmd:--}

  # $HOME을 ~로 치환
  cwd="${cwd/#$HOME/\~}"
  cmd="${cmd//$HOME/\~}"

  if [ "$verbose" -eq 0 ]; then
    # 첫 토큰 basename
    cmd_first="${cmd%% *}"
    cmd_rest="${cmd#* }"
    cmd_base="$(basename -- "$cmd_first")"

    if [ "$cmd_first" = "$cmd" ]; then
      cmd="$cmd_base"
    else
      # 나머지 토큰들 경로 축약
      new_rest=""
      for token in $cmd_rest; do
        if [[ "$token" == /* ]] || [[ "$token" == "~/"* ]]; then
          token="$(shorten_path "$token")"
        fi
        new_rest+="$token "
      done
      cmd="$cmd_base ${new_rest% }"
    fi

    # cwd도 축약
    cwd="$(shorten_path "$cwd")"
  fi

  # cmd 최대 길이 계산
  len=${#cmd}
  [ "$len" -gt "$max_cmd_len" ] && max_cmd_len="$len"

  lines+=("$s|$widx|$wname|$pidx|$cmd|$cwd")
done < <(tmux list-panes -a -F '#{session_name}|#{window_index}|#{window_name}|#{pane_index}|#{pane_tty}|#{pane_current_path}' 2>/dev/null | sort -t '|' -k1,1 -k2,2n -k4,4n)

# 출력
for line in "${lines[@]}"; do
  IFS='|' read -r s widx wname pidx cmd cwd <<< "$line"

  if [ "$s" != "$prev_s" ]; then
    if [ "$s" = "$cur_s" ]; then
      echo "* $s"
    else
      echo "  $s"
    fi
    prev_s="$s"
    prev_w=""
  fi

  if [ "$widx" != "$prev_w" ]; then
    if [ "$s" = "$cur_s" ] && [ "$widx" = "$cur_w" ]; then
      echo "    * ${widx}: ${wname}"
    else
      echo "      ${widx}: ${wname}"
    fi
    prev_w="$widx"
  fi

  if [ "$s" = "$cur_s" ] && [ "$widx" = "$cur_w" ] && [ "$pidx" = "$cur_p" ]; then
    printf "        * %s: %-${max_cmd_len}s  \"%s\"\n" "$pidx" "$cmd" "$cwd"
  else
    printf "          %s: %-${max_cmd_len}s  \"%s\"\n" "$pidx" "$cmd" "$cwd"
  fi
done
