#!/bin/bash
# mvt - tmux 세션 rename / 윈도우·pane 이동 및 이름 지정
#
# Usage:
#   mvt t1 t5              세션 rename
#   mvt t1:0 t5            윈도우 이동 (자동 번호)
#   mvt t1:0 t5:2          윈도우 이동 (지정 번호)
#   mvt t1:0 t5:train      윈도우 이동 후 이름 지정
#   mvt t1:train t5        이름 기반 윈도우 이동
#   mvt t1:0.0 t5:2        pane 이동 (좌우 분할, 기본)
#   mvt -h t1:0.0 t5:2     pane 이동 (좌우 분할)
#   mvt -v t1:0.0 t5:2     pane 이동 (위아래 분할)

split_opt="-h"

while getopts "hv" opt; do
  case $opt in
    h) split_opt="-h" ;;
    v) split_opt="-v" ;;
    *) echo "Usage: mvt [-h|-v] <src> <dst>" >&2; exit 1 ;;
  esac
done
shift $((OPTIND-1))

[ $# -ne 2 ] && { echo "Usage: mvt [-h|-v] <src> <dst>" >&2; exit 1; }

src="$1" dst="$2"

# 패턴 파싱
if [[ "$src" =~ ^([^:]+):([^.]+)\.([0-9]+)$ ]]; then
  src_s="${BASH_REMATCH[1]}" src_w="${BASH_REMATCH[2]}" src_p="${BASH_REMATCH[3]}"
elif [[ "$src" =~ ^([^:]+):([^.]+)$ ]]; then
  src_s="${BASH_REMATCH[1]}" src_w="${BASH_REMATCH[2]}" src_p=""
else
  src_s="$src" src_w="" src_p=""
fi

if [[ "$dst" =~ ^([^:]+):([^.]+)\.([0-9]+)$ ]]; then
  dst_s="${BASH_REMATCH[1]}" dst_w="${BASH_REMATCH[2]}" dst_p="${BASH_REMATCH[3]}"
elif [[ "$dst" =~ ^([^:]+):([^.]+)$ ]]; then
  dst_s="${BASH_REMATCH[1]}" dst_w="${BASH_REMATCH[2]}" dst_p=""
else
  dst_s="$dst" dst_w="" dst_p=""
fi

# 윈도우 tmux target reference 생성
win_ref() {
  local sess="$1" win="$2"
  if [[ "$win" =~ ^[0-9]+$ ]]; then
    echo "=$sess:$win"
  else
    echo "=$sess:=$win"
  fi
}

# Case 1: 세션 rename
if [ -z "$src_w" ] && [ -z "$dst_w" ]; then
  if tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -qx "$dst_s"; then
    echo "Session already exists: $dst_s" >&2
    exit 1
  fi
  tmux rename-session -t "=$src_s" "$dst_s"
  exit
fi

# Case 2: pane 이동
if [ -n "$src_p" ]; then
  if [ -n "$dst_w" ]; then
    if [[ "$dst_w" =~ ^[0-9]+$ ]]; then
      if ! tmux list-windows -t "=$dst_s" -F '#{window_index}' 2>/dev/null | grep -qx "$dst_w"; then
        tmux new-window -d -t "=$dst_s:$dst_w"
      fi
    else
      if ! tmux list-windows -t "=$dst_s" -F '#{window_name}' 2>/dev/null | grep -qx "$dst_w"; then
        tmux new-window -d -t "=$dst_s" -n "$dst_w"
      fi
    fi
  fi

  src_ref=$(win_ref "$src_s" "$src_w")
  if [ -n "$dst_p" ]; then
    dst_ref=$(win_ref "$dst_s" "$dst_w")
    tmux join-pane $split_opt -s "${src_ref}.${src_p}" -t "${dst_ref}.${dst_p}"
  elif [ -n "$dst_w" ]; then
    dst_ref=$(win_ref "$dst_s" "$dst_w")
    tmux join-pane $split_opt -s "${src_ref}.${src_p}" -t "$dst_ref"
  else
    tmux join-pane $split_opt -s "${src_ref}.${src_p}" -t "=$dst_s:"
  fi
  exit
fi

# Case 3: 윈도우 이동/이름 지정
if [ -n "$src_w" ]; then
  src_ref=$(win_ref "$src_s" "$src_w")

  if [ -n "$dst_w" ]; then
    if [[ "$dst_w" =~ ^[0-9]+$ ]]; then
      if tmux list-windows -t "=$dst_s" -F '#{window_index}' 2>/dev/null | grep -qx "$dst_w"; then
        tmux swap-window -s "$src_ref" -t "=$dst_s:$dst_w"
      else
        tmux move-window -d -s "$src_ref" -t "=$dst_s:$dst_w"
      fi
    else
      # 이름 지정: 같은 세션이면 rename, 다른 세션이면 이동 후 rename
      if [ "$src_s" = "$dst_s" ]; then
        tmux rename-window -t "$src_ref" "$dst_w"
      else
        orig_name=$(tmux display-message -t "$src_ref" -p '#{window_name}')
        tmux move-window -d -s "$src_ref" -t "=$dst_s:"
        tmux rename-window -t "=$dst_s:=$orig_name" "$dst_w"
      fi
    fi
  else
    tmux move-window -d -s "$src_ref" -t "=$dst_s:"
  fi
  exit
fi

echo "Invalid pattern" >&2
exit 1
